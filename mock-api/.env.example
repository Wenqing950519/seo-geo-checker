# You can put this file either here as mock-api/.env
# or in the project root as .env.
# Never commit real API keys.

PORT=8787

# Required for /api/test-provider and /api/audit-real-lite
AGNES_API_KEY=
AGNES_MODEL=agnes-2.0-flash
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1

# Optional but recommended for SEO/GEO visibility checks.
# Used by /api/test-search-provider, /api/search-context, and /api/audit-real-lite enrichment.
BRAVE_API_KEY=
BRAVE_SEARCH_BASE_URL=https://api.search.brave.com/res/v1
BRAVE_COUNTRY=TW
BRAVE_SEARCH_LANG=zh-hant
BRAVE_UI_LANG=zh-TW
BRAVE_SAFESEARCH=moderate

# Optional browser fallback for sites that block server-side fetch.
PLAYWRIGHT_NODE_MODULES=
DISABLE_BROWSER_FETCH=false

# MVP abuse controls. In production, replace in-memory limits with Redis.
RATE_LIMIT_IP_WINDOW_MS=600000
RATE_LIMIT_IP_MAX=10
RATE_LIMIT_URL_COOLDOWN_MS=1800000
MAX_ACTIVE_AUDITS=2

# Set to true only when running behind a trusted reverse proxy.
# When false, uses socket.remoteAddress to reduce IP spoofing risk.
TRUST_PROXY=false
